<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Pr01_SaraYueMadrugaMartin.InitialPage"
             Title="InitialPage">

    <!--Nueva pagina: la primera para pedir a los jugadores los nombres.-->
    
    <Grid>
        <Image Source="img_background.jpg"
               Aspect="AspectFill"/>

        <VerticalStackLayout Padding="30"
                             Spacing="20"
                             VerticalOptions="Center">

            <Label 
                Text="Introduce los nombres de los jugadores"
                FontSize="20"
                HorizontalOptions="Center" />

            <!-- Jugador 1 -->
            <Entry x:Name="Player1Entry"
                   Placeholder="Nombre del Jugador 1" />

            <!-- Jugador 2 -->
            <Entry x:Name="Player2Entry"
                   Placeholder="Nombre del Jugador 2" />

            <Button 
                Text="Comenzar partida"
                Clicked="OnStartClicked"
                HorizontalOptions="Center"/>

        </VerticalStackLayout>
    </Grid>
</ContentPage>